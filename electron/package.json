{
  "name": "needlework-studio",
  "version": "0.3.3",
  "description": "Needlework Studio — cross-stitch pattern management and design tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder"
  },
  "author": {
    "name": "GreenglassT",
    "email": "needleworkstudio@users.noreply.github.com"
  },
  "homepage": "https://github.com/GreenglassT/NeedleworkStudio",
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.needleworkstudio.app",
    "productName": "Needlework Studio",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../dist/needlework-backend",
        "to": "needlework-backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "GreenglassT",
      "repo": "NeedleworkStudio",
      "releaseType": "release"
    },
    "mac": {
      "icon": "resources/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": "-"
    },
    "dmg": {
      "background": "resources/dmg-background.png",
      "iconSize": 80,
      "iconTextSize": 12,
      "window": {
        "width": 660,
        "height": 440
      },
      "contents": [
        {
          "x": 186,
          "y": 200,
          "type": "file"
        },
        {
          "x": 474,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": "nsis"
    },
    "linux": {
      "icon": "resources/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Graphics"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
